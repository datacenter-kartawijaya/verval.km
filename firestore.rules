rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: projects
    // Fields: id, name, location, createdAt, createdBy
    //
    // Collection: certificates
    // Fields: projectId, albumNomor, noHak, jenisHak, namaPemegang, jenisSuratUkur, noSu, tahunSu, kecamatan, kelurahan, statusBT, statusSU, statusUpload, kendala, operatorId, operatorName, tanggalPengerjaan, updatedAt
    //
    // Collection: master_village_data
    // Fields: projectId, noHak, jenisHak, namaPemegang, jenisSuratUkur, noSu, tahunSu, kecamatan, kelurahan, isTaken, takenBy, takenByName, takenAt
    //
    // Collection: users
    // Fields: uid, email, displayName, username, password, role, assignedProjects
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == "datacenter.kartawijaya@gmail.com") ||
        (userExists() && (getUserData().role == 'superadmin' || getUserData().username == 'kartawijaya'))
      );
    }

    function isAdmin() {
      return isAuthenticated() && (
        isSuperAdmin() ||
        (userExists() && (getUserData().role == 'admin' || getUserData().role == 'superadmin'))
      );
    }

    function isOperator() {
      return isAuthenticated() && userExists() && (getUserData().role == 'operator' || getUserData().role == 'admin' || getUserData().role == 'superadmin');
    }

    function isAssignedToProject(projectId) {
      return isAuthenticated() && (
        isSuperAdmin() || 
        (userExists() && (
          getUserData().role == 'admin' || 
          getUserData().role == 'superadmin' ||
          (getUserData().role == 'operator' && 
           'assignedProjects' in getUserData() && 
           getUserData().assignedProjects.hasAny([projectId]))
        ))
      );
    }

    function isValidProject(data) {
      return data.keys().hasAll(['id', 'name', 'location', 'createdAt', 'createdBy']) &&
             data.id is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.location is string && data.location.size() > 0 && data.location.size() < 200 &&
             (!('description' in data) || data.description is string) &&
             data.createdAt is timestamp &&
             data.createdBy is string &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidCertificate(data) {
      return data.keys().hasAll(['projectId', 'noHak', 'jenisHak', 'statusBT', 'statusSU', 'statusUpload']) &&
             data.projectId is string &&
             data.noHak is string && data.noHak.size() > 0 && data.noHak.size() < 100 &&
             data.statusBT in ['Belum', 'Sudah', 'Terverifikasi'] &&
             data.statusSU in ['Belum', 'Sudah', 'Terverifikasi'] &&
             data.statusUpload in ['BT Belum', 'SU Belum', 'BT SU Belum', 'Sudah Upload BTSU'] &&
             (!('operatorId' in data) || data.operatorId is string) &&
             (!('operatorName' in data) || data.operatorName is string) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidMasterVillageData(data) {
      return data.keys().hasAll(['projectId', 'noHak', 'jenisHak', 'isTaken']) &&
             data.projectId is string &&
             data.noHak is string && data.noHak.size() > 0 && data.noHak.size() < 100 &&
             data.isTaken is bool &&
             (!('takenBy' in data) || data.takenBy is string) &&
             (!('takenByName' in data) || data.takenByName is string) &&
             (!('takenAt' in data) || data.takenAt is timestamp) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role']) &&
             data.role in ['superadmin', 'admin', 'operator'] &&
             (!('email' in data) || data.email is string) &&
             (!('username' in data) || data.username is string) &&
             (!('password' in data) || data.password is string) &&
             (!('assignedProjects' in data) || data.assignedProjects is list) &&
             (!('displayName' in data) || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('lastLogin' in data) || data.lastLogin is timestamp);
    }

    // Check if the user being created/updated by an admin only has projects the admin manages
    function adminOnlyAssignsManagedProjects(data) {
      return isSuperAdmin() || 
             !('assignedProjects' in data) || 
             (userExists() && getUserData().keys().hasAll(['assignedProjects']) && 
              data.assignedProjects.hasOnly(getUserData().assignedProjects));
    }

    function adminManagesUser(userData) {
      return isSuperAdmin() || 
             (userExists() && 
              getUserData().keys().hasAll(['assignedProjects']) && 
              userData.role == 'operator' && 
              userData.keys().hasAll(['assignedProjects']) && 
              userData.assignedProjects.hasAny(getUserData().assignedProjects));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      // Allow read for login (unauthenticated) and for authenticated users
      allow read: if true; 
      
      allow create: if isAuthenticated() && (
        isSuperAdmin() || 
        (isAdmin() && request.resource.data.role == 'operator' && adminOnlyAssignsManagedProjects(request.resource.data)) ||
        (uid == request.auth.uid && (
          (request.resource.data.role == 'superadmin' && request.resource.data.username == 'kartawijaya') ||
          (request.resource.data.role != 'superadmin')
        ))
      ) && isValidUser(request.resource.data);

      allow update: if isAuthenticated() && (
        isSuperAdmin() || 
        (isAdmin() && resource.data.role == 'operator' && request.resource.data.role == 'operator' && adminOnlyAssignsManagedProjects(request.resource.data)) ||
        (uid == request.auth.uid && request.resource.data.role == resource.data.role && request.resource.data.assignedProjects == resource.data.assignedProjects)
      ) && isValidUser(request.resource.data);

      allow delete: if isAuthenticated() && (
        request.auth.token.email == "datacenter.kartawijaya@gmail.com" || 
        isSuperAdmin() || 
        (isAdmin() && adminManagesUser(resource.data))
      );
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() && isValidProject(request.resource.data);
      allow update: if isAdmin() && isValidProject(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.token.email == "datacenter.kartawijaya@gmail.com" || isSuperAdmin());
    }

    match /certificates/{certificateId} {
      allow read: if isAuthenticated() && (isAssignedToProject(resource.data.projectId) || resource.data.operatorId == request.auth.uid);
      allow create: if isAuthenticated() && isAssignedToProject(request.resource.data.projectId) && isValidCertificate(request.resource.data);
      allow update: if isAuthenticated() && isAssignedToProject(resource.data.projectId) && isValidCertificate(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.token.email == "datacenter.kartawijaya@gmail.com" || isAdmin());
    }

    match /master_village_data/{id} {
      allow read: if isAuthenticated() && isAssignedToProject(resource.data.projectId);
      allow create: if isAdmin() && isValidMasterVillageData(request.resource.data);
      allow update: if isAuthenticated() && (
        isAdmin() || 
        (isOperator() && isAssignedToProject(resource.data.projectId) && 
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isTaken', 'takenBy', 'takenByName', 'takenAt']))
      ) && isValidMasterVillageData(request.resource.data);
      allow delete: if isAuthenticated() && (request.auth.token.email == "datacenter.kartawijaya@gmail.com" || isAdmin());
    }
  }
}
